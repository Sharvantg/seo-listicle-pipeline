# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is in .gitignore.

# Anthropic — article generation, eval, humanization
ANTHROPIC_KEY=sk-ant-...

# Serper — SERP top results + tool discovery searches
SERPER_API_KEY=your_serper_key

# MOZ Keyword Explorer — difficulty, volume, related keywords
# Value must be Base64-encoded "accessId:secretKey"
MOZ_API_KEY=base64_encoded_moz_access_id_and_secret

# Parallel.ai — async batch tool enrichment
PARALLEL_API_KEY=your_parallel_api_key

# Vercel AI Gateway — used for OpenAI GPT-4o calls in citation agent
VERCEL_AI_GATEWAY_KEY=vck_...

# Webflow CMS v2
WEBFLOW_API=your_webflow_api_token
WEBFLOW_COLLECTION_ID=your_collection_id

# Base URL used in prompts and eval (internal link target)
ZUDDL_BASE_URL=https://www.zuddl.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/parallel-webhook
